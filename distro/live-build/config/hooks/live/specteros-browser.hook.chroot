# ============================================
# 6. CREATE BROWSER PROFILES MANAGER
# ============================================

cat > /opt/specteros/browser/profiles.sh << 'SCRIPT'
#!/bin/bash
# SpecterOS Browser Profile Manager

PROFILE_DIR="$HOME/.mozilla/firefox"
SPECTEROS_PROFILE="$PROFILE_DIR/specteros-default"

case "$1" in
    "create")
        if [ ! -d "$SPECTEROS_PROFILE" ]; then
            mkdir -p "$SPECTEROS_PROFILE"
            cp /etc/skel/.mozilla/firefox/specteros-default/user.js "$SPECTEROS_PROFILE/"
            echo "profile.default=$SPECTEROS_PROFILE" > "$PROFILE_DIR/profiles.ini"
            echo "✓ SpecterOS profile created"
        else
            echo "✓ Profile already exists"
        fi
        ;;
    "reset")
        rm -rf "$SPECTEROS_PROFILE"
        mkdir -p "$SPECTEROS_PROFILE"
        cp /etc/skel/.mozilla/firefox/specteros-default/user.js "$SPECTEROS_PROFILE/"
        echo "✓ Profile reset"
        ;;
    "backup")
        tar -czf "$HOME/specteros-browser-backup-$(date +%Y%m%d).tar.gz" "$SPECTEROS_PROFILE"
        echo "✓ Backup created"
        ;;
    *)
        echo "Usage: $0 {create|reset|backup}"
        exit 1
        ;;
esac
SCRIPT

chmod +x /opt/specteros/browser/profiles.sh

# ============================================
# 7. CREATE FIRST-RUN SCRIPT
# ============================================

cat > /opt/specteros/browser/first-run.sh << 'SCRIPT'
#!/bin/bash
# Create SpecterOS Firefox profile on first run

PROFILE_DIR="$HOME/.mozilla/firefox"
SPECTEROS_PROFILE="$PROFILE_DIR/specteros-default"

if [ ! -d "$SPECTEROS_PROFILE" ]; then
    mkdir -p "$SPECTEROS_PROFILE"
    cp /etc/skel/.mozilla/firefox/specteros-default/user.js "$SPECTEROS_PROFILE/"
    echo "profile.default=$SPECTEROS_PROFILE" > "$PROFILE_DIR/profiles.ini"
fi

# Launch Firefox
firefox-esr --profile "$SPECTEROS_PROFILE" "$@"
SCRIPT

chmod +x /opt/specteros/browser/first-run.sh

# Update desktop entry to use first-run script
cat > /usr/share/applications/specteros-browser.desktop << 'EOF'
[Desktop Entry]
Name=SpecterOS Browser
Comment=Hardened Firefox ESR with maximum privacy + Brave-style ad blocking
Exec=/opt/specteros/browser/first-run.sh
Icon=firefox-esr
Terminal=false
Type=Application
Categories=Network;WebBrowser;
Keywords=privacy;security;browser;web;adblock;
EOF

# ============================================
# 8. CREATE SHIELD CONTROLLER (Brave Shields clone)
# ============================================

cat > /opt/specteros/browser/shield-controller.py << 'PYTHON'
#!/usr/bin/env python3
"""
SpecterOS Shield Controller
Brave Shields-style quick settings for ad blocking
"""

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk
import subprocess

class ShieldController(Gtk.Window):
    def __init__(self):
        super().__init__()
        
        self.set_default_size(320, 280)
        self.set_position(Gtk.WindowPosition.MOUSE)
        self.set_decorated(False)
        self.set_app_paintable(True)
        self.set_skip_taskbar_hint(True)
        
        main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main.set_margin_start(20)
        main.set_margin_end(20)
        main.set_margin_top(20)
        main.set_margin_bottom(20)
        self.add(main)
        
        # Header
        header = Gtk.Label(label="🛡️ Shields")
        header.get_style_context().add_class("header")
        main.pack_start(header, False, False, 10)
        
        # Toggles
        toggles = [
            ("🚫 Block Ads", True, "Blocks ads and trackers"),
            ("🔒 Block Scripts", False, "Block JavaScript (breaks sites)"),
            ("🎭 Fingerprinting", True, "Block fingerprinting"),
            ("🍪 Block Cookies", True, "Block third-party cookies"),
            ("🔐 HTTPS Only", True, "Force HTTPS connections"),
        ]
        
        for label, active, tooltip in toggles:
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
            box.set_margin_top(5)
            box.set_margin_bottom(5)
            
            lbl = Gtk.Label(label=label)
            lbl.set_halign(Gtk.Align.START)
            box.pack_start(lbl, True, True, 0)
            
            switch = Gtk.Switch()
            switch.set_active(active)
            switch.set_tooltip_text(tooltip)
            box.pack_start(switch, False, False, 0)
            
            main.pack_start(box, False, False, 0)
        
        # Footer buttons
        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        footer.set_margin_top(20)
        
        btn_advanced = Gtk.Button(label="Advanced")
        btn_advanced.get_style_context().add_class("btn-secondary")
        btn_advanced.connect("clicked", self.open_about)
        footer.pack_start(btn_advanced, True, True, 5)
        
        btn_close = Gtk.Button(label="Close")
        btn_close.get_style_context().add_class("btn-primary")
        btn_close.connect("clicked", lambda w: self.close())
        footer.pack_start(btn_close, True, True, 5)
        
        main.pack_start(footer, False, False, 0)
        
        self.apply_css()
        self.show_all()
    
    def apply_css(self):
        css = b"""
        window {
            background: rgba(15, 15, 22, 0.98);
            border: 1px solid rgba(0, 200, 170, 0.3);
            border-radius: 10px;
        }
        .header {
            font-size: 20px;
            font-weight: 700;
            color: #00c8aa;
        }
        label {
            color: #c0c0d0;
            font-size: 14px;
        }
        switch {
            background: #2a2a3a;
        }
        switch:checked {
            background: #00c8aa;
        }
        .btn-primary {
            background: #00c8aa;
            color: #000000;
            border: none;
            border-radius: 6px;
            padding: 8px 16px;
        }
        .btn-secondary {
            background: transparent;
            color: #8090a0;
            border: 1px solid #405060;
            border-radius: 6px;
            padding: 8px 16px;
        }
        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
    
    def open_about(self, widget):
        subprocess.Popen(["about:config"])

if __name__ == "__main__":
    controller = ShieldController()
    Gtk.main()
PYTHON

chmod +x /opt/specteros/browser/shield-controller.py

