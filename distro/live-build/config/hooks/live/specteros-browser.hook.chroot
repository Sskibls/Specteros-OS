#!/bin/bash
# SpecterOS Browser Hardening
# Firefox ESR with maximum privacy & security

set -e

# ============================================
# 1. INSTALL FIREFOX + AD BLOCKERS
# ============================================

apt-get update
apt-get install -y \
    firefox-esr \
    tor \
    torbrowser-launcher \
    || true

# Download and install uBlock Origin (same engine as Brave Shields)
mkdir -p /usr/lib/mozilla/extensions/{ec8030f7-c20a-464f-9b0e-13a3a9e97384}/{d10d0bf8-f5b5-c8b4-a8b2-2b9879e08c5d}
cd /tmp
curl -L -o ubo.xpi "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi" 2>/dev/null && unzip -o ubo.xpi -d /usr/lib/mozilla/extensions/{ec8030f7-c20a-464f-9b0e-13a3a9e97384}/{d10d0bf8-f5b5-c8b4-a8b2-2b9879e08c5d}/ || true
rm -f ubo.xpi

# Download Privacy Badger
curl -L -o pb.xpi "https://addons.mozilla.org/firefox/downloads/latest/privacy-badger/latest.xpi" 2>/dev/null && unzip -o pb.xpi -d /usr/lib/mozilla/extensions/{ec8030f7-c20a-464f-9b0e-13a3a9e97384}/privacy-badger@eff.org/ || true
rm -f pb.xpi

# HTTPS Everywhere is deprecated (built into Firefox now)
# Firefox has HTTPS-Only Mode enabled by default in our config

# ============================================
# 2. CREATE HARDENED FIREFOX PROFILE
# ============================================

FIREFOX_PROFILE="/etc/skel/.mozilla/firefox/specteros-default"
mkdir -p "$FIREFOX_PROFILE"

# Create user.js with hardened settings
cat > "$FIREFOX_PROFILE/user.js" << 'FIREFOX'
// SpecterOS Firefox Hardening Configuration
// Based on arkenfox-user.js + custom tweaks

// ============================================
// PRIVACY
// ============================================

// Disable telemetry
user_pref("datareporting.healthreport.uploadEnabled", false);
user_pref("datareporting.healthreport.service.enabled", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
user_pref("toolkit.telemetry.enabled", false);
user_pref("toolkit.telemetry.server", "");
user_pref("toolkit.telemetry.archive.enabled", false);
user_pref("toolkit.telemetry.coverage.opt-out", true);
user_pref("toolkit.coverage.opt-out", true);
user_pref("toolkit.coverage.endpoint.base", "");
user_pref("browser.newtabpage.activity-stream.feeds.telemetry", false);
user_pref("browser.newtabpage.activity-stream.telemetry", false);

// Disable crash reports
user_pref("breakpad.reportURL", "");
user_pref("browser.tabs.crashReporting.sendReport", false);
user_pref("browser.crashReports.unsubmittedCheck.enabled", false);

// Disable experiments
user_pref("experiments.supported", false);
user_pref("experiments.enabled", false);
user_pref("experiments.manifest.uri", "");

// Disable Pocket
user_pref("extensions.pocket.enabled", false);
user_pref("extensions.pocket.api", "");
user_pref("extensions.pocket.oAuthConsumerKey", "");
user_pref("extensions.pocket.site", "");

// Disable Firefox Home
user_pref("browser.newtabpage.enabled", false);
user_pref("browser.newtabpage.activity-stream.enabled", false);
user_pref("browser.newtabpage.activity-stream.showSearch", false);
user_pref("browser.newtabpage.activity-stream.feeds.topsites", false);
user_pref("browser.newtabpage.activity-stream.feeds.section.topstories", false);
user_pref("browser.newtabpage.activity-stream.feeds.section.highlights", false);
user_pref("browser.newtabpage.activity-stream.feeds.snippets", false);
user_pref("browser.newtabpage.activity-stream.showSponsored", false);
user_pref("browser.newtabpage.activity-stream.showSponsoredTopSites", false);

// ============================================
// SECURITY
// ============================================

// Disable JavaScript (optional - uncomment for maximum security)
// user_pref("javascript.enabled", false);

// Disable WebAssembly (optional - attack surface reduction)
// user_pref("javascript.options.wasm", false);

// Enable HTTPS-Only Mode
user_pref("dom.security.https_only_mode", true);
user_pref("dom.security.https_only_mode_ever_enabled", true);
user_pref("dom.security.https_only_mode_send_http_background_request", false);

// Disable mixed content
user_pref("security.mixed_content.block_display_content", true);
user_pref("security.mixed_content.upgrade_display_content", true);

// Strict CSP
user_pref("security.csp.enable", true);
user_pref("security.csp.reportOnly.enabled", false);

// Disable remote code execution features
user_pref("network.auth.subresource-http-auth-allow", 1);
user_pref("network.http.redirection-limit", 3);

// Disable service workers (tracking vector)
user_pref("dom.serviceWorkers.enabled", false);

// Disable WebRTC (IP leak prevention)
user_pref("media.peerconnection.enabled", false);
user_pref("media.peerconnection.ice.default_address_only", true);
user_pref("media.peerconnection.ice.no_host", true);

// Disable WebGL (fingerprinting + security)
user_pref("webgl.disabled", true);
user_pref("webgl.enable-webgl2", false);

// Disable battery API (fingerprinting)
user_pref("dom.battery.enabled", false);

// Disable device orientation API
user_pref("device.sensors.enabled", false);

// Disable geolocation
user_pref("geo.enabled", false);
user_pref("geo.provider.use_corelocation", false);
user_pref("geo.provider.use_gpsd", false);
user_pref("geo.provider.use_geoclue", false);

// ============================================
// FINGERPRINTING PROTECTION
// ============================================

// Resist fingerprinting
user_pref("privacy.resistFingerprinting", true);
user_pref("privacy.resistFingerprinting.letterboxing", true);
user_pref("privacy.resistFingerprinting.reduceTimer.precision", true);
user_pref("privacy.resistFingerprinting.reduceTimer.random", true);

// Spoof user agent
user_pref("general.useragent.override", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:109.0) Gecko/20100101 Firefox/115.0");

// Disable canvas fingerprinting
user_pref("canvas.capturestream.enabled", false);
user_pref("canvas.toBlob.enabled", false);

// Disable audio context fingerprinting
user_pref("audiocontext.enabled", false);

// Disable font fingerprinting
user_pref("browser.display.use_document_fonts", 0);

// ============================================
// NETWORK
// ============================================

// Disable DNS prefetching
user_pref("network.dns.disablePrefetch", true);
user_pref("network.dns.disablePrefetchFromHTTPS", true);
user_pref("network.dns.echsconfig.enabled", false);

// Disable link prefetching
user_pref("network.prefetch-next", false);

// Disable predictor/preload
user_pref("network.predictor.enabled", false);
user_pref("network.predictor.enable-prefetch", false);

// Disable speculative connections
user_pref("network.http.speculative-parallel-limit", 0);
user_pref("network.http.rcwn.enabled", false);

// Disable captive portal detection
user_pref("captivedetect.canonicalURL", "");
user_pref("network.captive-portal-service.enabled", false);

// Disable network connectivity checks
user_pref("network.connectivity-service.enabled", false);

// ============================================
// COOKIES & STORAGE
// ============================================

// Delete cookies on close
user_pref("network.cookie.lifetimePolicy", 2);
user_pref("network.cookie.lifetime.days", 0);

// Block third-party cookies
user_pref("network.cookie.cookieBehavior", 1);
user_pref("network.cookie.thirdparty.sessionOnly", true);

// Clear site data on close
user_pref("privacy.sanitize.sanitizeOnShutdown", true);
user_pref("privacy.clearOnShutdown.cache", true);
user_pref("privacy.clearOnShutdown.cookies", true);
user_pref("privacy.clearOnShutdown.downloads", true);
user_pref("privacy.clearOnShutdown.formdata", true);
user_pref("privacy.clearOnShutdown.history", true);
user_pref("privacy.clearOnShutdown.offlineApps", true);
user_pref("privacy.clearOnShutdown.sessions", true);
user_pref("privacy.clearOnShutdown.siteSettings", true);

// Disable DOM storage
user_pref("dom.storage.enabled", false);

// ============================================
// PASSWORDS & FORMS
// ============================================

// Disable password manager
user_pref("signon.rememberSignons", false);
user_pref("signon.autofillForms", false);
user_pref("signon.formlessCapture.enabled", false);

// Disable form autofill
user_pref("browser.formfill.enable", false);

// Disable address autofill
user_pref("extensions.formautofill.addresses.enabled", false);
user_pref("extensions.formautofill.creditCards.enabled", false);

// ============================================
// UBLOCK ORIGIN (Brave Shields equivalent)
// ============================================

// Enable uBlock Origin
user_pref("extensions.ublock0.enabled", true);

// uBlock Origin settings - Brave Shields style
user_pref("extensions.ublock0.userSettings.largeMediaSize", 50);
user_pref("extensions.ublock0.userSettings.advancedUserEnabled", true);

// Default filter lists (Brave-style blocking)
user_pref("extensions.ublock0.selectedFilterLists", [
    "ublock-filters",
    "ublock-badware",
    "ublock-privacy",
    "ublock-unbreak",
    "easylist",
    "easyprivacy",
    "adguard-base",
    "adguard-mobile",
    "fanboy-thirdparty_fonts",
    "plowe-0"
]);

// Enable cosmetic filtering
user_pref("extensions.ublock0.userSettings.cosmeticFilteringEnabled", true);

// Enable JavaScript blocking by default (optional)
// user_pref("extensions.ublock0.userSettings.noScripting", true);

// Block large media elements
user_pref("extensions.ublock0.userSettings.blockLargeMedia", true);

// Disable acceptable ads (Brave doesn't allow acceptable ads)
user_pref("extensions.ublock0.userSettings.acceptableAds", false);

// ============================================
// AGGRESSIVE AD BLOCKING (Brave-style)
// ============================================

// Block all third-party requests by default
user_pref("network.cookie.cookieBehavior", 1);

// Block tracking parameters in URLs
user_pref("privacy.query_stripping.enabled", true);
user_pref("privacy.query_stripping.strip_list", "fbclid,gclid,utm_source,utm_medium,utm_campaign,utm_content,utm_term");

// Block cryptocurrency miners
user_pref("privacy.trackingprotection.crypto_mining.enabled", true);

// Block fingerprinting scripts
user_pref("privacy.trackingprotection.fingerprinting.enabled", true);

// Block social media trackers
user_pref("privacy.trackingprotection.socialtracking.enabled", true);

// ============================================
// UI & BEHAVIOR
// ============================================

// Disable smooth scrolling (fingerprinting)
user_pref("general.smoothScroll", false);

// Disable reader mode
user_pref("browser.reader.detectedFirstArticle", true);

// Disable screenshots
user_pref("extensions.screenshots.disabled", true);
user_pref("extensions.screenshots.upload-disabled", true);

// Disable studies
user_pref("app.shield.optoutstudies.enabled", false);
user_pref("app.normandy.enabled", false);
user_pref("app.normandy.api_url", "");

// Disable default browser check
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.shell.skipDefaultBrowserCheckOnFirstRun", true);

// Disable welcome notification
user_pref("browser.startup.homepage_override.mstone", "ignore");

// ============================================
// DISK AVOIDANCE
// ============================================

// Disable disk cache
user_pref("browser.cache.disk.enable", false);
user_pref("browser.cache.memory.enable", true);
user_pref("browser.cache.memory.capacity", 256000);

// Disable download history
user_pref("browser.download.manager.addToRecentDocs", false);

// Disable session restore
user_pref("browser.sessionstore.enabled", false);
user_pref("browser.sessionstore.privacy_level", 2);

// ============================================
// SAFE BROWSING (optional - sends data to Google)
// ============================================

// Disable safe browsing (privacy tradeoff)
user_pref("browser.safebrowsing.malware.enabled", false);
user_pref("browser.safebrowsing.phishing.enabled", false);
user_pref("browser.safebrowsing.downloads.enabled", false);
user_pref("browser.safebrowsing.blockedURIs.enabled", false);
user_pref("browser.safebrowsing.provider.google4.enabled", false);
user_pref("browser.safebrowsing.provider.google.enabled", false);

// ============================================
// CUSTOM SPECTEROS START PAGE
// ============================================

user_pref("browser.startup.homepage", "about:blank");
user_pref("browser.newtab.url", "about:blank");
user_pref("browser.newtabpage.activity-stream.default.sites", "");
FIREFOX

# ============================================
# 3. CREATE SPECTEROS START PAGE
# ============================================

mkdir -p /usr/share/specteros/browser
cat > /usr/share/specteros/browser/start.html << 'HTML'
