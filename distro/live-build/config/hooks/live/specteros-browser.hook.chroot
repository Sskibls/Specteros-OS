Name=SpecterOS Browser
Comment=Hardened Firefox ESR with maximum privacy
Exec=firefox-esr --profile /home/%USER/.mozilla/firefox/specteros-default
Icon=firefox-esr
Terminal=false
Type=Application
Categories=Network;WebBrowser;
Keywords=privacy;security;browser;web;
EOF

